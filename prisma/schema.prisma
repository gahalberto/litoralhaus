generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CORRETOR
}

enum LeadStatus {
  NOVO
  EM_CONTATO
  QUALIFICADO
  VISITA_AGENDADA
  PROPOSTA
  FECHADO_GANHO
  FECHADO_PERDIDO
}

enum LeadSource {
  LANDING_PAGE
  WHATSAPP
  INSTAGRAM
  GOOGLE_ADS
  REFERRAL
  DIRECT
  MANUAL
}

enum BudgetRange {
  UP_TO_500K
  RANGE_500K_1M
  RANGE_1M_2M
  RANGE_2M_5M
  ABOVE_5M
}

enum PropertyType {
  APARTMENT
  HOUSE
  PENTHOUSE
  LAND
  COMMERCIAL
  CONDO
}

enum PropertyPurpose {
  VENDA
  LOCACAO
  TEMPORADA
}

enum PropertyStatus {
  DISPONIVEL
  RESERVADO
  VENDIDO
  ALUGADO
  DESISTENCIA
  OUTROS
}

enum InteractionChannel {
  WHATSAPP
  EMAIL
  PHONE
  VISIT
  VIDEO_CALL
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

enum Region {
  GUARUJA
  SANTOS
  SAO_VICENTE
  PRAIA_GRANDE
  BERTIOGA
  UBATUBA
  CARAGUATATUBA
  SAO_SEBASTIAO
  ILHABELA
}

enum LeadType {
  BUYER
  SELLER
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String   @unique
  password String
  role     UserRole @default(CORRETOR)
  active   Boolean  @default(true)
  avatar   String?

  assignedLeads     Lead[]
  propertiesCreated Property[]   @relation("PropertyCreatedBy")
  propertiesManaged Property[]   @relation("PropertyAgent")
  propertyLogs      PropertyLog[]

  @@index([role])
  @@index([active])
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String? @unique
  phone    String
  whatsapp String?

  type          LeadType       @default(BUYER)
  status        LeadStatus     @default(NOVO)
  source        LeadSource     @default(LANDING_PAGE)
  budgetRange   BudgetRange?
  regions       Region[]
  propertyTypes PropertyType[]
  notes         String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  referrerUrl String?

  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  score          Int     @default(0)

  interactions Interaction[]
  interests    PropertyInterest[]
  visits       Visit[]

  @@index([status])
  @@index([budgetRange])
  @@index([assignedUserId])
  @@index([createdAt])
}

// ─── Property ─────────────────────────────────────────────────────────────────

model Property {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identificação
  refCode     String?         @unique
  title       String
  slug        String          @unique
  description String?         @db.Text
  status      PropertyStatus  @default(DISPONIVEL)
  type        PropertyType    @default(APARTMENT)
  purposes    PropertyPurpose[]
  active            Boolean         @default(true)
  featured          Boolean         @default(false)
  isIsca            Boolean         @default(false)
  acceptsFinancing  Boolean         @default(false)
  exclusive         Boolean         @default(false)

  // Dados privativos
  averbada          Boolean         @default(false)
  escritura         Boolean         @default(false)
  placaImobiliaria  Boolean         @default(false)
  localChaves       String?

  // Categoria dinâmica (substituirá o enum type no futuro)
  categoryId  String?
  category    PropertyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Revisão periódica
  reviewIntervalDays Int       @default(90)
  nextReviewAt       DateTime?

  // Localização
  region            Region
  cep               String?
  city              String
  neighborhood      String
  address           String?
  addressNumber     String?
  showAddressNumber Boolean  @default(false)
  latitude          Decimal? @db.Decimal(10, 8)
  longitude         Decimal? @db.Decimal(11, 8)

  // Características
  bedrooms     Int?
  bathrooms    Int?
  suites       Int?
  parkingSpots Int?
  areaTotal    Decimal? @db.Decimal(10, 2)
  areaUsable   Decimal? @db.Decimal(10, 2)

  // Financeiro
  priceAsk  Decimal? @db.Decimal(15, 2)
  priceRent Decimal? @db.Decimal(15, 2)
  condoFee  Decimal? @db.Decimal(10, 2)
  iptu      Decimal? @db.Decimal(10, 2)

  // Mídia (URLs diretas — uma por item)
  images String[]

  // Diferenciais (relações com catálogo)
  highlights   PropertyHighlight[]
  amenities    PropertyAmenity[]
  proximities  PropertyProximity[]

  // Proprietário (visível só no admin)
  ownerName  String?
  ownerPhone String?
  ownerId    String?
  owner      Owner?  @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Responsáveis
  createdById String?
  createdBy   User?   @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  agentId     String?
  agent       User?   @relation("PropertyAgent", fields: [agentId], references: [id], onDelete: SetNull)

  // SEO
  seoTitle       String?
  seoDescription String?

  interests PropertyInterest[]
  visits    Visit[]
  logs      PropertyLog[]
  posts     PostProperty[]

  @@index([refCode])
  @@index([region, status])
  @@index([type, status])
  @@index([status])
  @@index([categoryId])
  @@index([isIsca])
  @@index([featured])
  @@index([priceAsk])
  @@index([nextReviewAt])
}

// ─── Categoria dinâmica de imóvel ─────────────────────────────────────────────

model PropertyCategory {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  name      String     @unique
  properties Property[]
}

// ─── Catálogo de Destaques ────────────────────────────────────────────────────

model Highlight {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  properties PropertyHighlight[]
}

model PropertyHighlight {
  propertyId  String
  highlightId String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@id([propertyId, highlightId])
  @@index([propertyId])
}

// ─── Catálogo de Proximidades ─────────────────────────────────────────────────

model Proximity {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  properties PropertyProximity[]
}

model PropertyProximity {
  propertyId  String
  proximityId String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  proximity   Proximity @relation(fields: [proximityId], references: [id], onDelete: Cascade)

  @@id([propertyId, proximityId])
  @@index([propertyId])
}

// ─── Catálogo de Comodidades ──────────────────────────────────────────────────

model Amenity {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([propertyId])
}

// ─── Interaction ──────────────────────────────────────────────────────────────

model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel     InteractionChannel
  direction   InteractionDirection @default(OUTBOUND)
  summary     String               @db.Text
  nextStep    String?
  nextStepAt  DateTime?
  performedBy String

  @@index([leadId])
  @@index([createdAt])
}

// ─── Owner ───────────────────────────────────────────────────────────────────

model Owner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  phone String
  email String?
  cpf   String?
  notes String? @db.Text

  properties Property[]
  history    OwnerHistory[]

  @@index([phone])
  @@index([name])
}

model OwnerHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  field     String
  oldValue  String?
  newValue  String?
  changedBy String

  @@index([ownerId])
  @@index([createdAt])
}

// ─── Visit ───────────────────────────────────────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  visitedAt   DateTime
  conductedBy String
  notes       String?  @db.Text

  @@index([propertyId])
  @@index([visitedAt])
}

// ─── PropertyInterest ─────────────────────────────────────────────────────────

model PropertyInterest {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  leadId     String
  propertyId String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  notes      String?

  @@unique([leadId, propertyId])
  @@index([leadId])
  @@index([propertyId])
}

// ─── PropertyLog ─────────────────────────────────────────────────────────────

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name    String
  email   String
  phone   String?
  subject String
  message String  @db.Text
  read    Boolean @default(false)

  @@index([read])
  @@index([createdAt])
}

model PropertyLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName   String

  action     String
  field      String?
  oldValue   String?
  newValue   String?

  @@index([propertyId])
  @@index([createdAt])
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title      String
  slug       String   @unique
  excerpt    String   @db.Text
  content    String   @db.Text
  coverImage String?

  published   Boolean   @default(false)
  publishedAt DateTime?

  authorName String @default("Litoral Haus")

  // Local SEO — bairro e cidade do artigo
  region       Region?
  city         String?
  neighborhood String?

  // Tags livres (ex: "mercado imobiliário", "dicas de compra")
  tags String[]

  // SEO overrides
  seoTitle       String?
  seoDescription String?

  relatedProperties PostProperty[]

  @@index([published, publishedAt])
  @@index([region])
  @@index([slug])
}

model PostProperty {
  postId     String
  propertyId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([postId, propertyId])
  @@index([postId])
  @@index([propertyId])
}
