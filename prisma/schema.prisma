generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CORRETOR
}

enum LeadStatus {
  NOVO
  EM_CONTATO
  QUALIFICADO
  VISITA_AGENDADA
  PROPOSTA
  FECHADO_GANHO
  FECHADO_PERDIDO
}

enum LeadSource {
  LANDING_PAGE
  WHATSAPP
  INSTAGRAM
  GOOGLE_ADS
  REFERRAL
  DIRECT
}

enum BudgetRange {
  UP_TO_500K
  RANGE_500K_1M
  RANGE_1M_2M
  RANGE_2M_5M
  ABOVE_5M
}

enum PropertyType {
  APARTMENT
  HOUSE
  PENTHOUSE
  LAND
  COMMERCIAL
  CONDO
}

enum PropertyStatus {
  DISPONIVEL
  RESERVADO
  VENDIDO
}

enum InteractionChannel {
  WHATSAPP
  EMAIL
  PHONE
  VISIT
  VIDEO_CALL
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

enum Region {
  GUARUJA
  SANTOS
  SAO_VICENTE
  PRAIA_GRANDE
  BERTIOGA
  UBATUBA
  CARAGUATATUBA
  SAO_SEBASTIAO
  ILHABELA
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String   @unique
  password String
  role     UserRole @default(CORRETOR)
  active   Boolean  @default(true)
  avatar   String?

  assignedLeads Lead[]

  @@index([role])
  @@index([active])
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String  @unique
  phone    String
  whatsapp String?

  status        LeadStatus   @default(NOVO)
  source        LeadSource   @default(LANDING_PAGE)
  budgetRange   BudgetRange
  regions       Region[]
  propertyTypes PropertyType[]
  notes         String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  referrerUrl String?

  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  score          Int     @default(0)

  interactions Interaction[]
  interests    PropertyInterest[]

  @@index([status])
  @@index([budgetRange])
  @@index([assignedUserId])
  @@index([createdAt])
}

// ─── Property ─────────────────────────────────────────────────────────────────

model Property {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identificação
  title       String
  slug        String         @unique
  description String?        @db.Text
  status      PropertyStatus @default(DISPONIVEL)
  type        PropertyType
  featured    Boolean        @default(false)
  isIsca      Boolean        @default(false)

  // Localização
  region       Region
  cep          String?
  city         String
  neighborhood String
  address      String?
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)

  // Características
  bedrooms     Int?
  bathrooms    Int?
  suites       Int?
  parkingSpots Int?
  areaTotal    Decimal?  @db.Decimal(10, 2)
  areaUsable   Decimal?  @db.Decimal(10, 2)

  // Financeiro
  priceAsk  Decimal?  @db.Decimal(15, 2)
  priceRent Decimal?  @db.Decimal(15, 2)
  condoFee  Decimal?  @db.Decimal(10, 2)
  iptu      Decimal?  @db.Decimal(10, 2)

  // Mídia (URLs diretas — uma por item)
  images String[]

  // Diferenciais (relações com catálogo)
  highlights PropertyHighlight[]
  amenities  PropertyAmenity[]

  // SEO
  seoTitle       String?
  seoDescription String?

  interests PropertyInterest[]

  @@index([region, status])
  @@index([type, status])
  @@index([isIsca])
  @@index([featured])
  @@index([priceAsk])
}

// ─── Catálogo de Destaques ────────────────────────────────────────────────────

model Highlight {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  properties PropertyHighlight[]
}

model PropertyHighlight {
  propertyId  String
  highlightId String
  property    Property  @relation(fields: [propertyId],  references: [id], onDelete: Cascade)
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@id([propertyId, highlightId])
  @@index([propertyId])
}

// ─── Catálogo de Comodidades ──────────────────────────────────────────────────

model Amenity {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId],  references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([propertyId])
}

// ─── Interaction ──────────────────────────────────────────────────────────────

model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel     InteractionChannel
  direction   InteractionDirection @default(OUTBOUND)
  summary     String               @db.Text
  nextStep    String?
  nextStepAt  DateTime?
  performedBy String

  @@index([leadId])
  @@index([createdAt])
}

// ─── PropertyInterest ─────────────────────────────────────────────────────────

model PropertyInterest {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  leadId     String
  propertyId String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  notes      String?

  @@unique([leadId, propertyId])
  @@index([leadId])
  @@index([propertyId])
}
